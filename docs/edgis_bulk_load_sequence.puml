@startuml edgis_bulk_load_script
title edgis_bulk_load.py - script flow

actor User
participant "__main__" as Entry
participant "setup_logging" as Logging
participant "edgis_bulk_load.main" as Main
participant "argparse" as Parser
participant "edgis_bulk_load.logic" as Logic
participant "ed_cache.bulk_load" as BulkLoad

User -> Entry : python src/edgis_bulk_load.py <initial_systems_csv> <max_nodes_visited>
Entry -> Logging : setup_logging()
Entry -> Main : main()
Main -> Parser : parse_args()
Parser --> Main : initial_systems, max_nodes_visited
Main -> Main : split and trim CSV seeds
Main -> Logic : logic(initial_system_names, max_nodes_visited)
Logic -> BulkLoad : bulk_load(initial_system_names, max_nodes_visited)
BulkLoad --> Logic : loaded_systems
Logic --> Main : loaded_systems
@enduml

@startuml ed_cache_bulk_load_service
title ed_cache.py - BulkLoadService.load

participant "ed_cache.bulk_load" as BulkLoadFn
participant "create_bulk_loader" as Factory
participant "BulkLoadService.load" as Load
participant "ThreadPoolExecutor" as Pool
participant "EDGisCache" as Cache

BulkLoadFn -> Factory : create_bulk_loader()
Factory --> BulkLoadFn : bulk_loader
BulkLoadFn -> Load : load(initial_system_names, max_nodes_visited, progress_callback)

Load -> Load : initialize queue, visited, visit_order
loop seed systems
  Load -> Cache : find_system_info(seed)
  Cache --> Load : seed payload | None
  Load -> Load : append valid seed payloads to queue
end

Load -> Load : worker_count = _physical_core_count()
Load -> Pool : create(max_workers=worker_count)

loop while queue not empty and visited < max
  Load -> Load : frontier = list(queue); queue.clear()
  Load -> Pool : map(_fetch_neighbors, frontier)
  loop each system in frontier
    Pool -> Load : _fetch_neighbors(system_info)
    Load -> Cache : find_system_neighbors(system_info)
    Cache --> Load : neighbors

    loop each neighbor
      alt invalid name or already visited
        Load -> Load : skip
      else new neighbor
        Load -> Load : add to visited + visit_order
        alt neighbor has coords
          Load -> Load : reuse neighbor payload
        else missing coords
          Load -> Cache : find_system_info(neighbor_name)
          Cache --> Load : full payload | None
        end
        Load -> Load : enqueue payload when available
      end
    end
  end

  opt every 512 visited
    Load --> BulkLoadFn : progress_callback("Loaded N of MAX systems")
  end
end

Load --> BulkLoadFn : visit_order
BulkLoadFn --> BulkLoadFn : log completion and return
@enduml
