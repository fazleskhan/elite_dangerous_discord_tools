@startuml
title edgis_bulk_load.py sequence

actor User
participant "__main__" as Entry
participant "resolve_log_level" as ResolveLog
participant "logging" as Logging
participant "main()" as Main
participant "argparse.ArgumentParser" as ArgParser
participant "logic(initial_system_name, number_of_systems)" as Logic
participant "db.DB" as DB
participant "EDGisCache.create" as CacheCreate
participant "EDGisCache instance" as Cache
participant "ed_bfs.travel" as Travel

User -> Entry: python src/edgis_bulk_load.py <initial_system> <system_count>
Entry -> ResolveLog: resolve_log_level(logging.INFO)
ResolveLog --> Entry: configured level
Entry -> Logging: basicConfig(level=...)
Entry -> Main: main()

Main -> ArgParser: ArgumentParser(...)
Main -> ArgParser: add_argument("initial_system")
Main -> ArgParser: add_argument("system_count", type=int)
Main -> ArgParser: parse_args()
ArgParser --> Main: args.initial_system, args.system_count
Main -> Logging: logger.info("Bulk load requested", ...)
Main -> Logic: logic(args.initial_system, args.system_count)

Logic -> Logging: logger.info("Starting bulk load traversal", ...)
Logic -> DB: DB(db_filename)
DB --> Logic: database
Logic -> CacheCreate: create(database)
CacheCreate --> Logic: cache

Logic -> Travel: travel(
cache.find_system_info,
cache.find_system_neighbors,
initial_system_name,
"Beagle Point",
number_of_systems,
0,
10000,
lambda _a, _b: 1.0)

activate Travel
loop BFS traversal (internal)
Travel -> Cache: find_system_info(system_name)
Cache --> Travel: system_info | None
Travel -> Cache: find_system_neighbors(system_info)
Cache --> Travel: neighbors
Travel -> Travel: queue/filter/visit nodes
end
Travel --> Logic: path | None
deactivate Travel

Logic -> Logging: logger.info("Bulk load traversal completed")
Logic --> Main: return
Main --> Entry: return
Entry --> User: process exits
@enduml
