@startuml
title edgis_bulk_load.py sequence

actor User
participant "__main__" as Entry
participant "setup_logging()" as SetupLogging
participant "main()" as Main
participant "argparse.ArgumentParser" as ArgParser
participant "logic(initial_system_names, max_nodes_visited)" as Logic
participant "create_bulk_loader()" as CreateBulkLoader
participant "ed_factory.create_datasource" as CreateDatasource
participant "datasource" as DB
participant "EDGisCache.create" as CacheCreate
participant "EDGisCache instance" as Cache
participant "BulkLoadService.create" as CreateService
participant "BulkLoadService.load" as LoadService

User -> Entry: python src/edgis_bulk_load.py <initial_systems> <max_nodes_visited>
Entry -> SetupLogging: setup_logging()
Entry -> Main: main()

Main -> ArgParser: ArgumentParser(...)
Main -> ArgParser: add_argument("initial_systems")
Main -> ArgParser: add_argument("max_nodes_visited", type=int)
Main -> ArgParser: parse_args()
ArgParser --> Main: args.initial_systems, args.max_nodes_visited
Main -> Main: split comma-separated seeds
Main -> Logic: logic(initial_system_names, max_nodes_visited)

Logic -> CreateBulkLoader: create_bulk_loader()
CreateBulkLoader -> CreateDatasource: create_datasource(None, None)
CreateDatasource --> CreateBulkLoader: datasource
CreateBulkLoader -> CacheCreate: EDGisCache.create(datasource)
CacheCreate --> CreateBulkLoader: cache
CreateBulkLoader -> CreateService: BulkLoadService.create(cache)
CreateService --> CreateBulkLoader: bulk_loader
CreateBulkLoader --> Logic: bulk_loader

Logic -> LoadService: load(initial_system_names,\nmax_nodes_visited,\nprogress_callback=logger.info)

activate LoadService
loop Seed initialization
  LoadService -> Cache: find_system_info(seed_name)
  Cache --> LoadService: system_info | None
  LoadService -> LoadService: enqueue seed info when present
end
loop BFS while queue not empty and visited < max
  LoadService -> Cache: find_system_neighbors(system_info)
  Cache --> LoadService: neighbors | []
  loop each neighbor
    LoadService -> LoadService: validate name and dedupe visited
    alt neighbor has coords(x,y,z)
      LoadService -> LoadService: reuse neighbor as queued system_info
    else missing coords
      LoadService -> Cache: find_system_info(neighbor_name)
      Cache --> LoadService: neighbor_system_info | None
    end
    LoadService -> LoadService: append to queue / visit_order
  end
  opt every 512 visited systems
    LoadService --> Logic: progress_callback("Loaded N of MAX systems")
  end
end
LoadService --> Logic: loaded_systems (list[str])
deactivate LoadService

Logic --> Main: loaded_systems
Main --> Entry: return
Entry --> User: process exits
@enduml
