@startuml
actor User
participant "main.py" as Main
participant Parser
participant EDMain
participant ILogger as Logger

User -> Main: invalid CLI invocation
Main -> Parser: parse_args()
Main -> Logger: info("CLI parameters")
Main -> EDMain: _run_command(args)
EDMain -> EDMain: validate required args
EDMain --> Main: raise CLIHandledError
Main -> Logger: error(message)
Main -> Logger: info(parser help)
Main --> User: exit 1 without traceback
@enduml
