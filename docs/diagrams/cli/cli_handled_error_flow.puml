@startuml
actor User
participant "main.py" as Main
participant Parser
participant "ed_cli_command_runner.py" as CommandRunner
participant EDMain
participant ILogger as Logger

User -> Main: invalid CLI invocation
Main -> Parser: parse_args()
Main -> Logger: info("CLI parameters")
Main -> CommandRunner: run_command(args, parser, ed_main)
CommandRunner -> CommandRunner: validate required args
CommandRunner --> Main: raise CLIHandledError
Main -> Logger: error(message)
Main -> Logger: info(parser help)
Main --> User: exit 1 without traceback
@enduml
