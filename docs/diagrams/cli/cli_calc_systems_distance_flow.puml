@startuml
actor User
participant "main.py" as Main
participant Parser
participant EDMain
participant EDRouteService as RouteService
participant ILogger as Logger

User -> Main: calc_systems_distance --initial --destination
Main -> Parser: parse_args()
Main -> Logger: info("CLI parameters")
Main -> EDMain: create(shared logger)
Main -> Logger: info("CLI command received")
Main -> EDMain: calc_systems_distance(source, target)
EDMain -> RouteService: calc_systems_distance(source, target)
RouteService --> EDMain: distance
EDMain --> Main: distance
Main -> Logger: info(distance)
Main -> Logger: info("Execution time")
@enduml
