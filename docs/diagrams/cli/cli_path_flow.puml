@startuml
actor User
participant "main.py" as Main
participant Parser
participant EDMain
participant EDRouteService as RouteService
participant ILogger as Logger

User -> Main: path --initial --destination --max_systems
Main -> Parser: parse_args()
Main -> Logger: info("CLI parameters")
Main -> EDMain: create(shared logger)
Main -> Logger: info("CLI command received")
Main -> EDMain: calc_route(...)
EDMain -> RouteService: path(..., progress_callback=logger.info)
RouteService --> EDMain: route or none
EDMain --> Main: route or none
alt route found
  Main -> Logger: info("A -> B -> C")
else no route found
  Main -> Logger: info(progress only)
end
Main -> Logger: info("Execution time")
@enduml
