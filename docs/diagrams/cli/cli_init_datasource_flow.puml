@startuml
actor User
participant "main.py" as Main
participant Parser
participant EDMain
participant EDRouteService as RouteService
participant ILogger as Logger

User -> Main: init_datasource --import_dir
Main -> Parser: parse_args()
Main -> Logger: info("CLI parameters")
Main -> EDMain: create(shared logger)
Main -> Logger: info("CLI command received")
Main -> EDMain: init_datasource(import_dir)
EDMain -> RouteService: init_datasource(import_dir)
RouteService --> EDMain: done
EDMain --> Main: done
Main -> Logger: info("Datasource initialized from ...")
Main -> Logger: info("Execution time")
@enduml
