@startuml
actor User
participant DiscordContext as Ctx
participant EDDiscordBot as Bot
participant EDRouteService as RouteService
participant ILogger as Logger

User -> Bot: init_datasource(ctx, import_dir)
Bot -> Logger: info("init_datasource command")
Bot -> RouteService: init_datasource(import_dir)
RouteService --> Bot: done
Bot -> Ctx: send("Datasource initialized from ...")
@enduml
