@startuml
actor User
participant DiscordContext as Ctx
participant EDDiscordBot as Bot
participant send_chunked_text as Chunker
participant EDRouteService as RouteService
participant ILogger as Logger

User -> Bot: system_info(ctx, system)
Bot -> Logger: info("system_info command")
Bot -> RouteService: get_system_info(system)
RouteService --> Bot: payload
alt payload <= 2000 chars
  Bot -> Ctx: send("system: payload (N ms)")
else payload > 2000 chars
  Bot -> Chunker: send_chunked_text(ctx, payload)
  loop per chunk
    Chunker -> Ctx: send(chunk)
  end
  Bot -> Ctx: send("Execution time: N ms")
end
@enduml
