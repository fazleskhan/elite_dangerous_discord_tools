@startuml all_loaded_systems
actor User
participant "CLI (argparse)" as CLI
participant "main.main" as Main
participant "EDRouteService" as Route

User -> CLI : python main.py all_loaded_systems
CLI -> Main : parsed args
Main -> Route : get_all_system_names()
Route --> Main : [system names]
Main --> User : print("All Loaded Systems: ...")
Main --> User : print("Execution time: <ms> ms")
@enduml

@startuml system_info
actor User
participant "CLI (argparse)" as CLI
participant "main.main" as Main
participant "EDRouteService" as Route

User -> CLI : python main.py system_info --system_name <name>
CLI -> Main : parsed args

alt missing --system_name
  Main --> User : print error + help
  Main --> User : exit(1)
else valid args
  Main -> Route : get_system_info(<name>)
  Route --> Main : system info | None
  Main --> User : print(<name>)
  Main --> User : print([system info])
  Main --> User : print("Execution time: <ms> ms")
end
@enduml

@startuml path
actor User
participant "CLI (argparse)" as CLI
participant "main.main" as Main
participant "main.calc_route" as CalcRoute
participant "EDRouteService" as Route

User -> CLI : python main.py path --initial A --destination B --max_systems N [--min_distance] [--max_distance]
CLI -> Main : parsed args

alt missing required args / max_systems > 1000
  Main --> User : print error + help/exit
else valid args
  Main -> CalcRoute : calc_route(A, B, N, min, max)
  CalcRoute -> Route : path(A, B, N, min, max, progress_callback)
  Route --> CalcRoute : [route] | None
  CalcRoute --> Main : [route] | None

  alt route found
    Main --> User : print("A → ... → B")
  else no route
    Main --> User : print("No route found")
  end

  Main --> User : print("Execution time: <ms> ms")
end
@enduml

@startuml calc_systems_distance
actor User
participant "CLI (argparse)" as CLI
participant "main.main" as Main
participant "EDRouteService" as Route

User -> CLI : python main.py calc_systems_distance --initial A --destination B
CLI -> Main : parsed args

alt missing required args
  Main --> User : print error + help
  Main --> User : exit(1)
else valid args
  Main -> Route : calc_systems_distance(A, B)
  Route --> Main : distance
  Main --> User : print(distance)
  Main --> User : print("Execution time: <ms> ms")
end
@enduml

@startuml init_datasource
actor User
participant "CLI (argparse)" as CLI
participant "main.main" as Main
participant "EDRouteService" as Route

User -> CLI : python main.py init_datasource [--import_dir]
CLI -> Main : parsed args
Main -> Route : init_datasource(import_dir)
Route --> Main : done
Main --> User : print("Datasource initialized from <import_dir>")
Main --> User : print("Execution time: <ms> ms")
@enduml
