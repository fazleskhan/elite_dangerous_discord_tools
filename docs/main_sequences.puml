@startuml main_ping
title main.py - ping

actor User
participant "main.main" as Main
participant "EDMain" as EDMain

User -> Main : command=ping
Main -> EDMain : create()
EDMain --> Main : ed_main
Main -> EDMain : ping()
EDMain --> Main : "Pong"
Main --> User : print("Pong")
@enduml

@startuml main_all_loaded_systems
title main.py - all_loaded_systems

actor User
participant "main.main" as Main
participant "EDMain" as EDMain
participant "EDRouteService" as Route

User -> Main : command=all_loaded_systems
Main -> EDMain : create()
EDMain --> Main : ed_main
Main -> EDMain : get_all_system_names()
EDMain -> Route : get_all_system_names()
Route --> EDMain : names
EDMain --> Main : names
Main --> User : print("All Loaded Systems: ...")
Main --> User : print("Execution time: <ms> ms")
@enduml

@startuml main_system_info
title main.py - system_info

actor User
participant "main.main" as Main
participant "EDMain" as EDMain
participant "EDRouteService" as Route

User -> Main : command=system_info --system_name <name>
Main -> EDMain : create()
EDMain --> Main : ed_main

alt missing --system_name
  Main --> User : print error + help
  Main --> User : exit(1)
else valid args
  Main -> EDMain : get_system_info([name])
  EDMain -> Route : get_system_info(name)
  Route --> EDMain : payload | None
  EDMain --> Main : [payload | None]
  Main --> User : print(name)
  Main --> User : print(payload list)
  Main --> User : print("Execution time: <ms> ms")
end
@enduml

@startuml main_path
title main.py - path

actor User
participant "main.main" as Main
participant "EDMain" as EDMain
participant "EDRouteService" as Route

User -> Main : command=path --initial A --destination B --max_systems N ...
Main -> EDMain : create()
EDMain --> Main : ed_main

alt missing --initial or --destination
  Main --> User : print error + help
  Main --> User : exit(1)
else max_systems > 1000
  Main --> User : print max_systems error
  Main --> User : exit(1)
else valid args
  Main -> EDMain : calc_route(A, B, N, min, max)
  EDMain -> Route : path(..., progress_callback=logging_utils.info)
  Route --> EDMain : route | None
  EDMain --> Main : route | None
  alt route found
    Main --> User : print("A → ... → B")
  else route not found
    Main --> User : print("Execution time only")
  end
  Main --> User : print("Execution time: <ms> ms")
end
@enduml

@startuml main_calc_systems_distance
title main.py - calc_systems_distance

actor User
participant "main.main" as Main
participant "EDMain" as EDMain
participant "EDRouteService" as Route

User -> Main : command=calc_systems_distance --initial A --destination B
Main -> EDMain : create()
EDMain --> Main : ed_main

alt missing required args
  Main --> User : print error + help
  Main --> User : exit(1)
else valid args
  Main -> EDMain : calc_systems_distance(A, B)
  EDMain -> Route : calc_systems_distance(A, B)
  Route --> EDMain : distance
  EDMain --> Main : distance
  Main --> User : print(distance)
  Main --> User : print("Execution time: <ms> ms")
end
@enduml

@startuml main_init_datasource
title main.py - init_datasource

actor User
participant "main.main" as Main
