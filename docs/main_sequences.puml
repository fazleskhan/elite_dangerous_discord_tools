@startuml Initialize Datasource Sequence Diagram
title main.py init_datasource

actor User
participant "CLI" as CLI
participant "argparse" as Parser
participant "main.main" as Main
participant "main.init_datasource" as InitDS
participant "EDRouteService" as Service
participant "stdout" as Out

User -> CLI: python src/main.py init_datasource [--import_dir <dir>]
CLI -> Main: main()
Main -> Parser: parse_args()
Parser --> Main: args.command=init_datasource, args.import_dir
Main -> InitDS: init_datasource(import_dir)
InitDS -> Service: init_datasource(import_dir)
Service --> InitDS: done
InitDS --> Main: done
Main -> Out: print("Datasource initialized from <dir>")
Main -> Out: print("Execution time: <ms> ms")
Main --> CLI: return
@enduml
