@startuml main_bulk_load_cache
title main.py - bulk_load_cache

actor User
participant "main.main" as Main
participant "EDMain" as EDMain
participant "EDRouteService" as Route

User -> Main : command=bulk_load_cache --initial_systems <csv> --max_nodes_visited N
Main -> EDMain : create()
EDMain --> Main : ed_main

alt missing required args
  Main --> User : print error + help
  Main --> User : exit(1)
else valid args
  Main -> Main : split and trim initial_systems CSV
  Main -> EDMain : bulk_load_cache(initial_system_names, N)
  EDMain -> Route : bulk_load_cache(initial_system_names, N, progress_callback=logging_utils.info)
  Route --> EDMain : loaded_systems
  EDMain --> Main : loaded_systems
  Main --> User : print("Loaded <count> systems from seeds [...]")
  Main --> User : print("Execution time: <ms> ms")
end
@enduml
