@startuml main_all_loaded_systems
title main.py - all_loaded_systems

actor User
participant "main.main" as Main
participant "EDRouteService.get_all_system_names" as Route

User -> Main : command=all_loaded_systems
Main -> Route : get_all_system_names()
Route --> Main : names
Main --> User : print("All Loaded Systems: ...")
Main --> User : print("Execution time: <ms> ms")
@enduml

@startuml main_system_info
title main.py - system_info

actor User
participant "main.main" as Main
participant "main.get_system_info" as GetInfo
participant "EDRouteService.get_system_info" as Route

User -> Main : command=system_info --system_name <name>
alt missing --system_name
  Main --> User : print error + help
  Main --> User : exit(1)
else valid args
  Main -> GetInfo : get_system_info([name])
  GetInfo -> Route : get_system_info(name)
  Route --> GetInfo : payload | None
  GetInfo --> Main : [payload | None]
  Main --> User : print(name)
  Main --> User : print(payload list)
  Main --> User : print("Execution time: <ms> ms")
end
@enduml

@startuml main_path
title main.py - path

actor User
participant "main.main" as Main
participant "main.calc_route" as CalcRoute
participant "EDRouteService.path" as Route

User -> Main : command=path --initial A --destination B --max_systems N ...
alt missing --initial or --destination
  Main --> User : print error + help
  Main --> User : exit(1)
else max_systems > 1000
  Main --> User : print max_systems error
  Main --> User : exit(1)
else valid args
  Main -> CalcRoute : calc_route(A, B, N, min, max)
  CalcRoute -> Route : path(..., progress_callback=logger.info)
  Route --> CalcRoute : route | None
  CalcRoute --> Main : route | None
  alt route found
    Main --> User : print("A → ... → B")
  else route not found
    Main --> User : print("No route found")
  end
  Main --> User : print("Execution time: <ms> ms")
end
@enduml

@startuml main_calc_systems_distance
title main.py - calc_systems_distance

actor User
participant "main.main" as Main
participant "main.calc_systems_distance" as Calc
participant "EDRouteService.calc_systems_distance" as Route

User -> Main : command=calc_systems_distance --initial A --destination B
alt missing required args
  Main --> User : print error + help
  Main --> User : exit(1)
else valid args
  Main -> Calc : calc_systems_distance(A, B)
  Calc -> Route : calc_systems_distance(A, B)
  Route --> Calc : distance
  Calc --> Main : distance
  Main --> User : print(distance)
  Main --> User : print("Execution time: <ms> ms")
end
@enduml

@startuml main_init_datasource
title main.py - init_datasource

actor User
participant "main.main" as Main
participant "main.init_datasource" as Init
participant "EDRouteService.init_datasource" as Route

User -> Main : command=init_datasource [--import_dir]
Main -> Init : init_datasource(import_dir)
Init -> Route : init_datasource(import_dir)
Route --> Init : done
Init --> Main : done
Main --> User : print("Datasource initialized from <import_dir>")
Main --> User : print("Execution time: <ms> ms")
@enduml

@startuml main_bulk_load_cache
title main.py - bulk_load_cache

actor User
participant "main.main" as Main
participant "main.bulk_load_cache" as Bulk
participant "EDRouteService.bulk_load_cache" as Route

User -> Main : command=bulk_load_cache --initial_systems <csv> --max_nodes_visited N
alt missing required args
  Main --> User : print error + help
  Main --> User : exit(1)
else valid args
  Main -> Main : split and trim initial_systems CSV
  Main -> Bulk : bulk_load_cache(initial_system_names, N)
  Bulk -> Route : bulk_load_cache(initial_system_names, N, progress_callback=logger.info)
  Route --> Bulk : loaded_systems
  Bulk --> Main : loaded_systems
  Main --> User : print("Loaded <count> systems from seeds [...]")
  Main --> User : print("Execution time: <ms> ms")
end
@enduml
