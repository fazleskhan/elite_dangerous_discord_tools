@startuml
title dump_system_cache_names — detailed sequence
actor User
participant Discord as "discord.py"
participant Bot as "DiscordBot"
participant AsyncRoute as "ed_route_async"
participant Route as "ed_route"
database DB as "TinyDB (data/*.db)"

User -> Discord: `!dump_system_cache_names`
Discord -> Bot: invoke dump_system_cache_names(ctx)
Bot -> Bot: ctx.send("Fetching all system names in cache... This may take a while")
Bot -> AsyncRoute: get_all_system_names()
AsyncRoute -> Route: get_all_system_names()
Route -> DB: open DB file
Route -> DB: get_all_systems()
DB --> Route: [system_info1, system_info2, system_info3, ...]
Route -> Route: extract names from system_info list
Route --> AsyncRoute: ["Sol", "Alpha Centauri", ...]
AsyncRoute --> Bot: system_names_list
Bot -> Bot: chunked_system_list(system_names, size=10)
alt first chunk
    Bot -> Discord: ctx.send("Systems in cache: Sol, Alpha Centauri, ...")
    ...
end
alt subsequent chunks
    Bot -> Discord: ctx.send("Systems in cache: <next chunk>")
    ...
end
Bot -> Discord: ctx.send("Total number of systems in cache: <len(system_names)>")
@enduml
