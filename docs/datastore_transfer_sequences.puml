@startuml Import Tinydb Sequence Diagram
title import_tinydb.py main()

actor User
participant "CLI" as CLI
participant "argparse.ArgumentParser" as Parser
participant "import_tinydb.main" as Main
participant "Path/os.getenv" as Env
participant "EDTinyDB" as TinyDB

User -> CLI: python src/import_tinydb.py [--import-dir DIR]
CLI -> Main: main()
Main -> Parser: parse_args()
Parser --> Main: args.import_dir
Main -> Env: resolve repo_root/data/ed_route.db
Main -> Env: DB_LOCATION override lookup
Env --> Main: db_path
Main -> TinyDB: EDTinyDB(db_path)
TinyDB --> Main: tinydb
Main -> TinyDB: import_datasource(args.import_dir)
TinyDB --> Main: imported
Main --> CLI: return
@enduml

