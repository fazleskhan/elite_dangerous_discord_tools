@startuml import_tinydb
title import_tinydb.py

actor User
participant "CLI (argparse)" as CLI
participant "import_tinydb.main" as Main
participant "EDLoggingUtils" as Logging
participant "EDTinyDB" as TinyDB

User -> CLI : python src/import_tinydb.py [--import-dir]
CLI -> Main : parse_args()
Main -> Logging : EDLoggingUtils.create()
Logging --> Main : logging_utils
Main -> TinyDB : EDTinyDB.create(logging_utils)
TinyDB --> Main : tinydb
Main -> TinyDB : import_datasource(args.import_dir)
TinyDB --> Main : done
Main --> User : process exit
@enduml

