@startuml import_redis
actor User
participant "CLI (argparse)" as CLI
participant "import_redis.main" as Main
participant "EDRedis Factory" as RedisFactory
participant "EDRedis" as RedisDB

User -> CLI : python src/import_redis.py [--import-dir]
CLI -> Main : parsed args
Main -> RedisFactory : EDRedis.create()
RedisFactory --> Main : redis_db
Main -> RedisDB : import_datasource(import_dir)
RedisDB --> Main : done
Main --> User : process exit
@enduml

@startuml export_redis
actor User
participant "CLI (argparse)" as CLI
participant "export_redis.main" as Main
participant "EDRedis Factory" as RedisFactory
participant "EDRedis" as RedisDB

