@startuml Import Redis Sequence Diagram
title import_redis.py main()

actor User
participant "CLI" as CLI
participant "argparse.ArgumentParser" as Parser
participant "import_redis.main" as Main
participant "EDRedis" as Redis

User -> CLI: python src/import_redis.py [--import-dir DIR]
CLI -> Main: main()
Main -> Parser: parse_args()
Parser --> Main: args.import_dir
Main -> Redis: EDRedis(database_name="ed_route")
Redis --> Main: redis_db
Main -> Redis: import_datasource(args.import_dir)
Redis --> Main: imported
Main --> CLI: return
@enduml

