Bot -> Ctx : send("Pong (<ms> ms)")
@enduml

@startuml ed_discord_bot_system_info
title ed_discord_bot.py - !system_info

actor User
participant "Discord Gateway" as Gateway
participant "EDDiscordBot.system_info" as Bot
participant "RouteServiceProtocol" as Route
participant "Discord Context" as Ctx

User -> Gateway : !system_info <system>
Gateway -> Bot : system_info(ctx, arg)
Bot -> Route : get_system_info(arg)
Route --> Bot : system_info | None

alt response <= 2000 chars
  Bot -> Ctx : send("<system>: <payload> (<ms> ms)")
else response > 2000 chars
  loop each 2000-char chunk
    Bot -> Ctx : send(chunk)
  end
  Bot -> Ctx : send("Execution time: <ms> ms")
end
@enduml

@startuml ed_discord_bot_path
title ed_discord_bot.py - !path

actor User
participant "Discord Gateway" as Gateway
participant "EDDiscordBot.path" as Bot
participant "RouteServiceProtocol" as Route
participant "Event Loop" as Loop
participant "Discord Context" as Ctx

User -> Gateway : !path <start> <destination> [max_count] [min_dist] [max_dist]
Gateway -> Bot : path(ctx, start, destination, ...)
Bot -> Ctx : send("Calculate Path ... This may take a while")
Bot -> Route : path(..., progress_callback)

loop progress callback (optional)
  Route -> Bot : progress_callback(message)
  Bot -> Loop : run_coroutine_threadsafe(ctx.send(message), loop)
  Loop -> Ctx : send(message)
end

Route --> Bot : route | []
alt route found
  Bot -> Ctx : send("Route from ... (<ms> ms)")
else no route
  Bot -> Ctx : send("No Path found ... (<ms> ms)")
end
@enduml

