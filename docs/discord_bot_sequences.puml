@startuml discord_bot_ping
title discord_bot.py - !ping

actor User
participant "Discord Gateway" as Gateway
participant "DiscordBot.ping" as Bot
participant "Discord Context" as Ctx

User -> Gateway : !ping
Gateway -> Bot : ping(ctx)
Bot -> Ctx : send("Pong (<ms> ms)")
@enduml

@startuml discord_bot_system_info
title discord_bot.py - !system_info

actor User
participant "Discord Gateway" as Gateway
participant "DiscordBot.system_info" as Bot
participant "RouteService.get_system_info" as Route
participant "Discord Context" as Ctx

User -> Gateway : !system_info <system>
Gateway -> Bot : system_info(ctx, arg)
Bot -> Route : get_system_info(arg)
Route --> Bot : payload | None

alt payload <= 2000 chars
  Bot -> Ctx : send("<arg>: <payload> (<ms> ms)")
else payload > 2000 chars
  loop each 2000-char chunk
    Bot -> Ctx : send(chunk)
  end
  Bot -> Ctx : send("Execution time: <ms> ms")
end
@enduml

@startuml discord_bot_path
title discord_bot.py - !path

actor User
participant "Discord Gateway" as Gateway
participant "DiscordBot.path" as Bot
participant "RouteService.path" as Route
participant "Discord Context" as Ctx
participant "Event Loop" as Loop

User -> Gateway : !path <initial> <destination> [max] [min] [max_distance]
Gateway -> Bot : path(ctx, initial, destination, ...)
Bot -> Ctx : send("Calculate Path ... This may take a while")
Bot -> Route : path(..., progress_callback)

loop progress callback
  Route -> Bot : progress_callback(message)
  Bot -> Loop : run_coroutine_threadsafe(ctx.send(message), loop)
  Loop -> Ctx : send(message)
end

Route --> Bot : route | None
alt route found
  Bot -> Ctx : send("Route from ... (<ms> ms)")
else no route
  Bot -> Ctx : send("No Path found ... (<ms> ms)")
end
@enduml

