@startuml
title DiscordBot.path(ctx, initial_system_name, destination_system_name, max_system_count, min_distance, max_distance)

actor User
participant "discord.py Dispatcher" as Dispatcher
participant "Discord command wrapper" as Command
participant "DiscordBot" as Bot
participant "RouteService (ed_route)" as Route
participant "Worker thread" as Worker
participant "concurrent.futures.Future" as SendFuture
participant "commands.Context" as Ctx

User -> Dispatcher: !path <initial> <destination> [max_system_count] [min_distance] [max_distance]
Dispatcher -> Command: path(ctx, initial, destination, max_system_count, min_distance, max_distance)
Command -> Bot: path(ctx, initial, destination, max_system_count, min_distance, max_distance)
Bot -> Bot: start = perf_counter()
Bot -> Ctx: send("Calculate Path between ... This may take a while")
Ctx --> Bot: sent

Bot -> Bot: loop = get_running_loop()
Bot -> Route: path(initial, destination, max_systems=max_system_count,\nmin_distance=min_distance, max_distance=max_distance,\nprogress_callback=progress_callback)
loop progress updates during traversal
  Route -> Worker: progress_callback(message)
  Worker -> Bot: logger.info(message)
  Worker -> SendFuture: run_coroutine_threadsafe(ctx.send(message), loop)
  Worker -> SendFuture: add_done_callback(handle_progress_send_result)
  SendFuture -> Ctx: send(progress_message)
  Ctx --> SendFuture: sent | exception
  alt send failed
    SendFuture -> Bot: handle_progress_send_result(future.exception())
    Bot -> Bot: logger.error("Failed to send progress update to Discord")
  else send ok
  end
end

Route --> Bot: route | awaitable
Bot -> Bot: _resolve(route)
alt awaitable
  Bot -> Bot: await route
else immediate
end

alt route is None or empty
  Bot -> Bot: message = "No Path found ..."
else route found
  Bot -> Bot: route_message = " -> ".join(route)
  Bot -> Bot: message = "Route from ..."
end

Bot -> Bot: elapsed_ms = int((perf_counter()-start)*1000)
Bot -> Ctx: send("<message>(<ms> ms)")
Ctx --> Bot: sent
Bot --> Command: return
Command --> Dispatcher: return
@enduml

@startuml
title DiscordBot.dump_system_cache_names(ctx)

actor User
participant "discord.py Dispatcher" as Dispatcher
participant "Discord command wrapper" as Command
participant "DiscordBot" as Bot
participant "RouteService (ed_route)" as Route
participant "commands.Context" as Ctx

User -> Dispatcher: !dump_system_cache_names
Dispatcher -> Command: dump_system_cache_names(ctx)
Command -> Bot: dump_system_cache_names(ctx)
Bot -> Bot: start = perf_counter()
Bot -> Ctx: send("Fetching all system names in cache... This may take a while")
Ctx --> Bot: sent

Bot -> Route: get_all_system_names()
Route --> Bot: names | awaitable
Bot -> Bot: _resolve(names)
alt awaitable
  Bot -> Bot: await names
else immediate
end

loop each chunk in chunked_system_list(names, size=10)
  Bot -> Ctx: send("Systems in cache: ...")
  Ctx --> Bot: sent
end

Bot -> Bot: elapsed_ms = int((perf_counter()-start)*1000)
Bot -> Ctx: send("Total number of systems in cache: <count> (<ms> ms)")
Ctx --> Bot: sent
Bot --> Command: return
Command --> Dispatcher: return
@enduml

