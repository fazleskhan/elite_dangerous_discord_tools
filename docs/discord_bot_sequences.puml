@startuml
title DiscordBot.ping(ctx)

actor User
participant "discord.py Dispatcher" as Dispatcher
participant "DiscordBot wrapper" as Wrapper
participant "DiscordBot" as Bot
participant "commands.Context" as Ctx

User -> Dispatcher: !ping
Dispatcher -> Wrapper: ping(ctx)
Wrapper -> Bot: ping(ctx)
Bot -> Bot: start = perf_counter()
Bot -> Bot: elapsed_ms = int((perf_counter()-start)*1000)
Bot -> Ctx: send("Pong (<ms> ms)")
Ctx --> Bot: sent
Bot --> Wrapper: return
Wrapper --> Dispatcher: return
@enduml

@startuml
title DiscordBot.system_info(ctx, arg)

actor User
participant "discord.py Dispatcher" as Dispatcher
participant "DiscordBot wrapper" as Wrapper
participant "DiscordBot" as Bot
participant "RouteService (ed_route)" as Route
participant "commands.Context" as Ctx

User -> Dispatcher: !system_info <arg>
Dispatcher -> Wrapper: system_info(ctx, arg)
Wrapper -> Bot: system_info(ctx, arg)
Bot -> Bot: start = perf_counter()
Bot -> Route: get_system_info(arg)
Route --> Bot: value | awaitable
Bot -> Bot: _resolve(value)
alt awaitable
  Bot -> Bot: await value
else immediate
end
Bot -> Bot: s_info = str(system_info)
alt len(s_info) <= 2000
  Bot -> Bot: elapsed_ms = int((perf_counter()-start)*1000)
  Bot -> Ctx: send("<arg>: <system_info> (<ms> ms)")
else len(s_info) > 2000
  loop each 2000-char chunk
    Bot -> Ctx: send(chunk)
  end
  Bot -> Bot: elapsed_ms = int((perf_counter()-start)*1000)
  Bot -> Ctx: send("Execution time: <ms> ms")
end
Ctx --> Bot: sent
Bot --> Wrapper: return
Wrapper --> Dispatcher: return
@enduml

