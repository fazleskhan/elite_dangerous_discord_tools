@startuml discord_bot_dump_system_cache_names
title discord_bot.py - !dump_system_cache_names

actor User
participant "Discord Gateway" as Gateway
participant "DiscordBot.dump_system_cache_names" as Bot
participant "RouteService.get_all_system_names" as Route
participant "Discord Context" as Ctx

User -> Gateway : !dump_system_cache_names
Gateway -> Bot : dump_system_cache_names(ctx)
Bot -> Ctx : send("Fetching all system names in cache... This may take a while")
Bot -> Route : get_all_system_names()
Route --> Bot : system names
loop chunks of 10
  Bot -> Ctx : send("Systems in cache: <chunk>")
end
Bot -> Ctx : send("Total number of systems in cache: <n> (<ms> ms)")
@enduml

