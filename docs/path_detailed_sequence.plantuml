@startuml
title path — detailed traversal (cache miss + neighbor fetches)
actor User
participant Discord as "discord.py"
participant Bot as "DiscordBot"
participant AsyncRoute as "ed_route_async"
participant Route as "ed_route"
participant Cache as "Ed_Cache"
participant BFS as "ed_bfs"
database DB as "TinyDB (data/*.db)"
participant EDGIS as "EDGIS API"

User -> Discord: `!path Sol Alpha Centauri`
Discord -> Bot: invoke path(ctx, "Sol", "Alpha Centauri")
Bot -> AsyncRoute: path("Sol", "Alpha Centauri")
AsyncRoute -> Route: path("Sol", "Alpha Centauri")
Route -> Route: initialize_preloaded_db()
Route -> DB: open DB file
Route -> Cache: Ed_Cache(database)
Route -> BFS: travel(cache.find_system_info, cache.find_system_neighbors, "Sol", "Alpha Centauri")
BFS -> Cache: find_system_info("Sol")
Cache -> DB: get_system("Sol")
DB --> Cache: null
Cache -> EDGIS: GET /coords?q=Sol
EDGIS --> Cache: {Sol system_info}
Cache -> DB: insert_system(Sol)
Cache --> BFS: return Sol system_info
BFS -> Cache: find_system_neighbors(Sol)
Cache -> DB: get_system("Sol")
DB --> Cache: neighbors null
Cache -> EDGIS: GET /neighbors?x=...&y=...&z=...
EDGIS --> Cache: [neighbor1, neighbor2]
Cache -> DB: add_neighbors(Sol, [neighbor1, neighbor2])
Cache --> BFS: return neighbors list
BFS -> Cache: find_system_info(neighbor1)
Cache -> DB: get_system(neighbor1)
DB --> Cache: null
Cache -> EDGIS: GET /coords?q=neighbor1
EDGIS --> Cache: {neighbor1 info}
Cache -> DB: insert_system(neighbor1)
Cache --> BFS: neighbor1 info
BFS -> BFS: enqueue path [Sol, neighbor1]
... repeat neighbor fetches and info lookups until destination reached ...
BFS --> Route: return ["Sol", "...", "Alpha Centauri"]
Route --> AsyncRoute: return route
AsyncRoute --> Bot: await resolves with route
Bot -> Discord: ctx.send("Route from Sol to Alpha Centauri: Sol → ... → Alpha Centauri")
@enduml
