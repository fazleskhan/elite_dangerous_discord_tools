@startuml
actor User
participant "Discord Gateway" as Gateway
participant "commands.Bot" as Bot
participant "DiscordBot" as DB
participant "Context (ctx)" as Ctx
participant "Discord REST API" as API

User -> Gateway : POST message "!ping" in channel
Gateway -> Bot : on_message / dispatch command
Bot -> Bot : parse command prefix
Bot -> Bot : lookup handler → ping(ctx)
Bot -> DB : ping wrapper(ctx)
activate DB
DB -> Ctx : await ctx.send("Pong")
activate Ctx
Ctx -> API : POST /channels/{id}/messages
deactivate Ctx
API -> Gateway : message event
Gateway -> User : deliver "Pong" in channel
deactivate DB
@enduml