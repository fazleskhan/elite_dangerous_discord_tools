{
  "console": {
    "enabled": true,
    "level": "DEBUG",
    "colorize": true,
    "format": "<green>{time:YYYY-MM-DD HH:mm:ss}</green> | <level>{level: <8}</level> | <cyan>tid={thread.id}</cyan> | <cyan>{name}</cyan>:<cyan>{function}</cyan>:<cyan>{line}</cyan> | <level>{message}</level>"
  },
  "file": {
    "enabled": true,
    "path": "logs/application.log",
    "level": "DEBUG",
    "rotation": "00:00",
    "retention_days": 14,
    "archive_directory": "logs/archive",
    "format": "{time:YYYY-MM-DD HH:mm:ss} | {level: <8} | tid={thread.id} | {name}:{function}:{line} | {message}"
  },
  "watch": {
    "enabled": true
  }
}
