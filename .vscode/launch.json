{
    // Use IntelliSense to learn about possible attributes.
    // Hover to view descriptions of existing attributes.
    // For more information, visit: https://go.microsoft.com/fwlink/?linkid=830387
    "version": "0.2.0",
    "configurations": [
        {
            "name": "Main -h",
            "type": "debugpy",
            "request": "launch",
            "program": "${workspaceFolder}/src/main.py",
            "console": "integratedTerminal",
            "args": "-h"
        },
        {
            "name": "Main System Info",
            "type": "debugpy",
            "request": "launch",
            "program": "${workspaceFolder}/src/main.py",
            "console": "integratedTerminal",
            "args": "system_info --system_name 'Sol'"
        },
        {
            "name": "Main Path",
            "type": "debugpy",
            "request": "launch",
            "program": "${workspaceFolder}/src/main.py",
            "console": "integratedTerminal",
            "args": "path --initial 'Sol' --destination 'Sirius' --max_systems 100"
        },        
        {
            "name": "Discord Bot",
            "type": "debugpy",
            "request": "launch",
            "program": "${workspaceFolder}/src/discord_runner.py",
            "console": "integratedTerminal"
        },           
        {
            "name": "EDGIS Bulk Load -h",
            "type": "debugpy",
            "request": "launch",
            "program": "${workspaceFolder}/src/edgis_bulk_load.py",
            "console": "integratedTerminal",
            "args": "-h"
        },        
        {
            "name": "EDGIS Bulk Load Sol 10",
            "type": "debugpy",
            "request": "launch",
            "program": "${workspaceFolder}/src/edgis_bulk_load.py",
            "console": "integratedTerminal",
            "args": "Sol 10"
        },         
        {
            "name": "Python Debugger: Current File",
            "type": "debugpy",
            "request": "launch",
            "program": "${file}",
            "console": "integratedTerminal"
        }
    ]
}