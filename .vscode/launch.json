{
    // Use IntelliSense to learn about possible attributes.
    // Hover to view descriptions of existing attributes.
    // For more information, visit: https://go.microsoft.com/fwlink/?linkid=830387
    "version": "0.2.0",
    "configurations": [
        {
            "name": "Main -h",
            "type": "debugpy",
            "request": "launch",
            "program": "${workspaceFolder}/src/main.py",
            "console": "integratedTerminal",
            "args": "-h"
        },
        {
            "name": "Main System Info",
            "type": "debugpy",
            "request": "launch",
            "program": "${workspaceFolder}/src/main.py",
            "console": "integratedTerminal",
            "args": "system_info --system_name 'Sol'"
        },
        {
            "name": "Main Path",
            "type": "debugpy",
            "request": "launch",
            "program": "${workspaceFolder}/src/main.py",
            "console": "integratedTerminal",
            "args": "path --initial 'Sol' --destination 'Sirius' --max_systems 100 --min_distance=5 --max_distance=10"
        },        
        {
            "name": "Discord Bot - Default",
            "type": "debugpy",
            "request": "launch",
            "program": "${workspaceFolder}/src/discord_runner.py",
            "console": "integratedTerminal"
        },                   
        {
            "name": "Discord Bot - TinyDB",
            "type": "debugpy",
            "request": "launch",
            "program": "${workspaceFolder}/src/discord_runner.py",
            "console": "integratedTerminal",
            "env": {
                "DATASTORE_TYPE": "tinydb"
            }            
        },                   
        {
            "name": "Discord Bot - Redis",
            "type": "debugpy",
            "request": "launch",
            "program": "${workspaceFolder}/src/discord_runner.py",
            "console": "integratedTerminal",
            "env": {
                "DATASTORE_TYPE": "redis"
            }            
        },                   
        {
            "name": "EDGIS Bulk Load -h",
            "type": "debugpy",
            "request": "launch",
            "program": "${workspaceFolder}/src/edgis_bulk_load.py",
            "console": "integratedTerminal",
            "args": "-h"
        },        
        {
            "name": "EDGIS Bulk Load Sol 10",
            "type": "debugpy",
            "request": "launch",
            "program": "${workspaceFolder}/src/edgis_bulk_load.py",
            "console": "integratedTerminal",
            "args": "Sol 10"
        },      
        {
            "name": "Main Calc Systems Distance",
            "type": "debugpy",
            "request": "launch",
            "program": "${workspaceFolder}/src/main.py",
            "console": "integratedTerminal",
            "args": "calc_systems_distance --initial 'Sol' --destination 'Sirius'"
        },           
        {
            "name": "Main Initialize Datasource",
            "type": "debugpy",
            "request": "launch",
            "program": "${workspaceFolder}/src/main.py",
            "console": "integratedTerminal",
            // Use --import_dir to override the default ./init source folder.
            "args": "init_datasource"
        },           
        {
            "name": "Export ED TinyDB",
            "type": "debugpy",
            "request": "launch",
            "program": "${workspaceFolder}/src/export_tinydb.py",
            "console": "integratedTerminal"
        },            
        {
            "name": "Export ED Redis",
            "type": "debugpy",
            "request": "launch",
            "program": "${workspaceFolder}/src/export_redis.py",
            "console": "integratedTerminal"
        },            
        {
            "name": "Import ED Redis",
            "type": "debugpy",
            "request": "launch",
            "program": "${workspaceFolder}/src/import_redis.py",
            "console": "integratedTerminal"
        },     
        {
            "name": "Import ED TinyDB",
            "type": "debugpy",
            "request": "launch",
            "program": "${workspaceFolder}/src/import_tinydb.py",
            "console": "integratedTerminal"
        },               
        {
            "name": "Python Debugger: Current File",
            "type": "debugpy",
            "request": "launch",
            "program": "${file}",
            "console": "integratedTerminal"
        }
    ]
}
