// For format details, see https://aka.ms/devcontainer.json. For config options, see the
// README at: https://github.com/devcontainers/templates/tree/main/src/python
{
	"name": "Elite Dangerous Discord Tools",
	// Or use a Dockerfile or Docker Compose file. More info: https://containers.dev/guide/dockerfile
	"image": "mcr.microsoft.com/devcontainers/python:3.14-bookworm",
	 "runArgs": ["--name", "Elite_Dangerous_Discord_Tools"],
	  
  	"features": {
    	"ghcr.io/devcontainers/features/docker-outside-of-docker:1": {}
  	},

  	// Optional: Mount the host Docker socket into the container
  	"mounts": [
    {
      "source": "/var/run/docker.sock",
      "target": "/var/run/docker.sock",
      "type": "bind"
    }
    ],

	// Use 'postCreateCommand' to run commands after the container is created.
	"postCreateCommand": "sh ./scripts/postCreateCommand.sh",

	// Configure tool-specific properties.
	"customizations": {
		"vscode": {
			"extensions": [
				"ms-python.python",
				"ms-python.black-formatter",
				"codezombiech.gitignore",
				"jebbs.plantuml",
				"ms-python.autopep8",
				"Redis.redis-for-vscode",
				"ms-python.vscode-pylance",
				"ms-python.debugpy",
				"ms-python.vscode-python-envs",
				"elijah-potter.harper",
				"Gruntfuggly.todo-tree",
				"openai.chatgpt"
			],
			"settings": {
				"[python]": {
					"editor.defaultFormatter": "ms-python.black-formatter",
					"editor.formatOnSave": true,
				    "python.testing.unittestEnabled": false,
    				"python.testing.pytestEnabled": true,
    				"plantuml.server": "https://www.plantuml.com/plantuml",
    				"plantuml.render": "PlantUMLServer",
    				"plantuml.exportOutDir": "/docs",
    				"plantuml.exportFormat": "png",
    				"plantuml.diagramsRoot": "/docs"
				}
			}
		}
	}	
}
